# ============================================================
# Click Print — environment variables
# Copy to .env.local for local dev, and add the same in Vercel
# (Project → Settings → Environment Variables) for production.
# ============================================================

# --- Supabase (Phase 1: database + file storage) ---
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://clickprint.in

# --- Razorpay (Phase 2: real payments) — not needed yet ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- AI image generation (Phase 5) — not needed yet ---
# GEMINI_API_KEY=
